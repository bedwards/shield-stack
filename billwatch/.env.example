# Supabase (NEXT_PUBLIC_ prefix needed for client-side access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRICE_ID=price_your-premium-plan-price-id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Supabase service role (server-only — bypasses RLS, for webhooks and admin ops)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# EIA (U.S. Energy Information Administration) — server-only
# Register free at https://www.eia.gov/opendata/
EIA_API_KEY=your-eia-api-key

# App
TEST_MODE=false
NEXT_PUBLIC_APP_URL=http://localhost:3001
