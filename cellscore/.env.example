# Supabase (NEXT_PUBLIC_ prefix needed for client-side access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mapbox (NEXT_PUBLIC_ prefix for client-side geocoding)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# Stripe (server-only — no NEXT_PUBLIC_ prefix)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# App
TEST_MODE=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
